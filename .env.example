# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
JWT_SECRET=replace-me-with-a-long-random-secret
LOW_STOCK_THRESHOLD=5

# Super Admin
SUPER_ADMIN_NAME=Platform Admin
SUPER_ADMIN_EMAIL=admin@inventra.app
SUPER_ADMIN_PHONE=+231700000000
SUPER_ADMIN_PASSWORD=AdminPass123
SUPER_ADMIN_SETUP_SECRET=replace-me-with-a-setup-secret

# Resend Email Service
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Inventra <onboarding@resend.dev>
RESEND_FALLBACK_FROM_EMAIL=Inventra <onboarding@resend.dev>
RESEND_TEST_EMAIL=you@example.com

# Token Expiry
ACTIVATION_TOKEN_EXPIRY_HOURS=24

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret
CLOUDINARY_UPLOAD_FOLDER=inventra/profile-photos
